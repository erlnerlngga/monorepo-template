{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e ../../.env --",
    "dev": "pnpm with-env tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:generate": "pnpm with-env prisma generate",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:push": "pnpm with-env prisma db push",
    "db:studio": "pnpm with-env prisma studio",
    "start": "pnpm with-env tsx src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.20",
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@repo/config": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/telemetry": "workspace:*",
    "better-auth": "^1.6.20",
    "hono": "^4.12.26",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
